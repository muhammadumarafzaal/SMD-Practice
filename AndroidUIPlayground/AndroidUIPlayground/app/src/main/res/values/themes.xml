<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.UIPlayground" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorPrimaryVariant">@color/grad_end</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Card Style -->
    <style name="CardStyle">
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <!-- Section Label Style -->
    <style name="SectionLabel">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Screen Title -->
    <style name="ScreenTitle">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <!-- Stat Number -->
    <style name="StatNumber">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Stat Label -->
    <style name="StatLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
