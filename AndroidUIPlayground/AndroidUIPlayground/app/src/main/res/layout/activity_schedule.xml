<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════╗
    ║  activity_schedule.xml                                   ║
    ║  CONCEPT: TableLayout + TableRow                         ║
    ║  Demonstrates: TableRow, stretchColumns, shrinkColumns,  ║
    ║  collapseColumns, layout_column, layout_span,            ║
    ║  padding, margin, gravity in cells                       ║
    ╚══════════════════════════════════════════════════════════╝
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_padding_top">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="@color/accent_purple"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TableLayout"
                android:textColor="@color/accent_yellow"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:background="@drawable/chip_course_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/schedule_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xxl"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fall Semester 2024"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:text="WEEKLY TIMETABLE"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <!--
            ╔═══════════════════════════════════════════════════╗
            ║  TableLayout                                       ║
            ║  stretchColumns="*" → all columns share width     ║
            ║  shrinkColumns="1,2,3,4,5" → can shrink if needed ║
            ╚═══════════════════════════════════════════════════╝
        -->
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*"
            android:shrinkColumns="1,2,3,4,5"
            android:background="@drawable/card_bg">

            <!-- HEADER ROW -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/table_header_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Time"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Mon"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Tue"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Wed"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Thu"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Fri"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />
            </TableRow>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- ROW 1: 08:00 -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:00"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <!-- Algo cell with color -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Algo"
                    android:textColor="@color/bg_dark"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding"
                    android:background="@color/accent_cyan" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Algo"
                    android:textColor="@color/bg_dark"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding"
                    android:background="@color/accent_cyan" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Algo"
                    android:textColor="@color/bg_dark"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="@dimen/table_cell_padding"
                    android:background="@color/accent_cyan" />
            </TableRow>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- ROW 2: 10:00 (alternate background) -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/table_row_alt_bg">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:00" android:textColor="@color/text_hint" android:textSize="10sp" android:fontFamily="monospace" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OS" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_yellow" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OS" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_yellow" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
            </TableRow>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- ROW 3: 12:00 -->
            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12:00" android:textColor="@color/text_hint" android:textSize="10sp" android:fontFamily="monospace" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DB" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_purple" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DB" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_purple" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DB" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_purple" />
            </TableRow>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- ROW 4: 14:00 (alternate) -->
            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/table_row_alt_bg">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="14:00" android:textColor="@color/text_hint" android:textSize="10sp" android:fontFamily="monospace" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mobile" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_green" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mobile" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_green" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
            </TableRow>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

            <!-- ROW 5: 16:00 -->
            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="16:00" android:textColor="@color/text_hint" android:textSize="10sp" android:fontFamily="monospace" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ML" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_orange" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ML" android:textColor="@color/bg_dark" android:textSize="10sp" android:textStyle="bold" android:gravity="center" android:padding="@dimen/table_cell_padding" android:background="@color/accent_orange" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="@color/text_hint" android:textSize="10sp" android:gravity="center" android:padding="@dimen/table_cell_padding" />
            </TableRow>

        </TableLayout>

        <!-- Legend -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="LEGEND"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <!--
            Another TableLayout for the legend
            Uses layout_span to merge cells
        -->
        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1"
            android:background="@drawable/card_bg"
            android:padding="4dp">

            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/accent_cyan" android:layout_marginEnd="8dp" android:layout_marginStart="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Algorithms" android:textColor="@color/text_secondary" android:textSize="12sp" android:padding="4dp" />
            </TableRow>

            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/accent_yellow" android:layout_marginEnd="8dp" android:layout_marginStart="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Operating Systems" android:textColor="@color/text_secondary" android:textSize="12sp" android:padding="4dp" />
            </TableRow>

            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/accent_purple" android:layout_marginEnd="8dp" android:layout_marginStart="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Databases" android:textColor="@color/text_secondary" android:textSize="12sp" android:padding="4dp" />
            </TableRow>

            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/accent_green" android:layout_marginEnd="8dp" android:layout_marginStart="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mobile Development" android:textColor="@color/text_secondary" android:textSize="12sp" android:padding="4dp" />
            </TableRow>

            <TableRow android:layout_width="match_parent" android:layout_height="wrap_content">
                <View android:layout_width="20dp" android:layout_height="20dp" android:background="@color/accent_orange" android:layout_marginEnd="8dp" android:layout_marginStart="8dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Machine Learning" android:textColor="@color/text_secondary" android:textSize="12sp" android:padding="4dp" />
            </TableRow>

        </TableLayout>

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
